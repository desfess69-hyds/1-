# Anthropic Claude API 키 — https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-여기에_본인_키_넣기

# (선택) Claude 모델 — 비워두면 기본값 사용
ANTHROPIC_MODEL=claude-sonnet-4-5

# (선택) Instagram Graph API — Phase 3에서 추가
# IG_USER_ID=
# IG_ACCESS_TOKEN=

# === Phase 3: 앱 DB 연결 ===
# MySQL/TiDB Cloud — Railway → Variables 에서 DATABASE_URL 복사
DATABASE_URL=

# === 텔레그램 알림 (앱과 동일한 봇 재사용) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# === 노션 자동 정리 (수련회 종료 시 아카이브) ===
NOTION_TOKEN=secret_여기에_Integration_Internal_Token
NOTION_DATABASE_ID=노션_DB_ID_32자

# === reels_studio (릴스 auto 모드 영상 엔진) — Phase 2 ===
# step3 영상 생성 — fal.ai (Atlas Cloud에서 전환 진행 중). https://fal.ai/dashboard/keys
FAL_KEY=
# step2 음성 합성 — ElevenLabs. https://elevenlabs.io 에서 발급
ELEVENLABS_API_KEY=
# (선택) ElevenLabs 보이스 ID — 비워두면 스크립트 기본값
ELEVENLABS_VOICE_ID=
# step1 대본 생성 — 로컬 Ollama (API 키 불필요, 기본 http://localhost:11434)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
